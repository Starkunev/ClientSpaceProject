<Window x:Class="WpfApp1.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPACE PROFILE"
        Height="780"
        Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#050816">

    <!-- ================= RESOURCES ================= -->
    <Window.Resources>

        <!-- BUTTON -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#7C4DFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.07" ScaleY="1.07"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- INPUT -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <!-- COMBO SAFE -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

    </Window.Resources>

    <!-- ================= BACKGROUND ================= -->
    <Grid>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#050816"/>
                <GradientStop Color="#111C44" Offset="0.5"/>
                <GradientStop Color="#311B92" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- ================= CARD ================= -->
        <Border Margin="20"
                Background="#161625"
                CornerRadius="20"
                Padding="20">

            <StackPanel>

                <TextBlock Text="🚀 SPACE PROFILE"
                           Foreground="White"
                           FontSize="26"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <!-- AVATAR -->
                <Border Width="130"
                        Height="130"
                        CornerRadius="65"
                        HorizontalAlignment="Center"
                        ClipToBounds="True"
                        BorderBrush="#7C4DFF"
                        BorderThickness="2">

                    <Image x:Name="AvatarImage"/>
                </Border>

                <Button Content="CHANGE AVATAR"
                        Style="{StaticResource Btn}"
                        Margin="0,10"
                        Click="ChangeAvatar_Click"/>

                <!-- USERNAME -->
                <TextBlock Text="USERNAME"
                           Foreground="#00E5FF"/>

                <TextBox x:Name="NameBox"/>

                <!-- STATUS -->
                <TextBlock Text="STATUS"
                           Foreground="#00E5FF"
                           Margin="0,10,0,0"/>

                <TextBox x:Name="StatusBox"/>

                <!-- ABOUT -->
                <TextBlock Text="ABOUT"
                           Foreground="#00E5FF"
                           Margin="0,10,0,0"/>

                <TextBox x:Name="AboutBox"
                         Height="80"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"/>

                <!-- THEME (FIXED SAFE VERSION) -->
                <TextBlock Text="THEME"
                           Foreground="#00E5FF"
                           Margin="0,10,0,0"/>

                <ComboBox x:Name="ThemeBox"
                          SelectedIndex="0"
                          Background="DarkBlue" Foreground="White"
                          Margin="0,5,0,10">

                    <ComboBoxItem Content="Dark"/>
                    <ComboBoxItem Content="Purple"/>
                    <ComboBoxItem Content="NeonBlue"/>
                    <ComboBoxItem Content="SpaceBlack"/>

                </ComboBox>

                <!-- IP -->
                <TextBlock Text="IP ADDRESS"
                           Foreground="#00E5FF"/>

                <TextBlock x:Name="IpText"
                           Foreground="White"
                           Margin="0,5,0,10"/>

                <!-- INFO PANEL -->
                <Border Background="#22000000"
                        CornerRadius="12"
                        Padding="10"
                        Margin="0,0,0,10">

                    <StackPanel>

                        <TextBlock Text="PROFILE SYNC STATUS"
                                   Foreground="#00E5FF"
                                   FontSize="12"/>

                        <TextBlock Text="• Avatar sync enabled"
                                   Foreground="#AAA"
                                   FontSize="11"/>

                        <TextBlock Text="• Theme live update"
                                   Foreground="#AAA"
                                   FontSize="11"/>

                        <TextBlock Text="• User online tracking"
                                   Foreground="#AAA"
                                   FontSize="11"/>

                    </StackPanel>

                </Border>

                <!-- SAVE -->
                <Button Content="SAVE PROFILE"
                        Height="45"
                        Background="#00E5FF"
                        Foreground="Black"
                        FontWeight="Bold"
                        Click="SaveButton_Click">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                </Button>

            </StackPanel>

        </Border>

    </Grid>

</Window>