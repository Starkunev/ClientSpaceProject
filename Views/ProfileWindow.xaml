<Window x:Class="WpfApp1.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SPACE PROFILE"
        Height="780"
        Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#050816">

   
    <Window.Resources>

       
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#7C4DFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.07" ScaleY="1.07"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

       
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

       
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

    </Window.Resources>

    
    <Grid Margin="0,0,0,-182">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#050816"/>
                <GradientStop Color="#111C44" Offset="0.5"/>
                <GradientStop Color="#311B92" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

      
        <Border Margin="20"
                Background="#161625"
                CornerRadius="20"
                Padding="20">

            <StackPanel>

                <TextBlock Text="🚀 SPACE PROFILE"
                           Foreground="White"
                           FontSize="26"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

               
                <Border Width="130"
                        Height="130"
                        CornerRadius="65"
                        HorizontalAlignment="Center"
                        ClipToBounds="True"
                        BorderBrush="#7C4DFF"
                        BorderThickness="2">

                    <Image x:Name="AvatarImage"/>
                </Border>

                <Button Content="CHANGE AVATAR"
                        Style="{StaticResource Btn}"
                        Margin="0,10"
                        Click="ChangeAvatar_Click"/>

           
                <TextBlock Text="USERNAME"
                           Foreground="#00E5FF"/>

                <TextBox x:Name="NameBox"/>

              
                <TextBlock Text="STATUS"
                           Foreground="#00E5FF"
                           Margin="0,10,0,0"/>

                <TextBox x:Name="StatusBox"/>

          
                <TextBlock Text="ABOUT"
                           Foreground="#00E5FF"
                           Margin="0,10,0,0"/>

                <TextBox x:Name="AboutBox"
                         Height="80"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"/>

              
                <TextBlock Text="THEME"
                           Foreground="#00E5FF"
                           Margin="0,10,0,0"/>

                <ComboBox x:Name="ThemeBox"
                          SelectedIndex="0"
                          Background="DarkBlue" Foreground="White"
                          Margin="0,5,0,10">

                    <ComboBoxItem Content="Dark"/>
                    <ComboBoxItem Content="Purple"/>
                    <ComboBoxItem Content="NeonBlue"/>
                    <ComboBoxItem Content="SpaceBlack"/>

                </ComboBox>

         
                <TextBlock Text="IP ADDRESS"
                           Foreground="#00E5FF"/>

                <TextBlock x:Name="IpText"
                           Foreground="White"
                           Margin="0,5,0,10"/>

 
                <Border Background="#22000000"
                        CornerRadius="12"
                        Padding="10"
                        Margin="0,0,0,10">

                    <StackPanel>

                        <TextBlock Text="PROFILE SYNC STATUS"
                                   Foreground="#00E5FF"
                                   FontSize="12"/>

                        <TextBlock Text="• Avatar sync enabled"
                                   Foreground="#AAA"
                                   FontSize="11"/>

                        <TextBlock Text="• Theme live update"
                                   Foreground="#AAA"
                                   FontSize="11"/>

                        <TextBlock Text="• User online tracking"
                                   Foreground="#AAA"
                                   FontSize="11"/>

                    </StackPanel>

                </Border>

                <!-- СЕКЦИЯ СМЕНЫ ПАРОЛЯ -->
                <Border Background="#1E1E2E" 
        CornerRadius="12" 
        Padding="15" 
        Margin="0,10,0,10">

                    <StackPanel>
                        <TextBlock Text="🔒 СМЕНА ПАРОЛЯ" 
                   Foreground="#FF6B6B" 
                   FontWeight="Bold" 
                   FontSize="14"
                   Margin="0,0,0,8"/>

                        <TextBlock Text="Новый пароль (мин. 6 символов)" 
                   Foreground="#00E5FF" 
                   FontSize="12"
                   Margin="0,0,0,3"/>

                        <PasswordBox x:Name="NewPasswordBox" 
                     Background="#2A2A3C" 
                     Foreground="White"
                     BorderThickness="0" 
                     Padding="8"
                     Height="35"/>

                        <TextBlock Text="Подтверждение пароля" 
                   Foreground="#00E5FF" 
                   FontSize="12"
                   Margin="0,8,0,3"/>

                        <PasswordBox x:Name="ConfirmPasswordBox" 
                     Background="#2A2A3C" 
                     Foreground="White"
                     BorderThickness="0" 
                     Padding="8"
                     Height="35"/>

                        <Button x:Name="ChangePasswordButton"
                Content="СМЕНИТЬ ПАРОЛЬ" 
                Height="35" 
                Background="#FF6B6B" 
                Foreground="White"
                FontWeight="Bold"
                Click="ChangePassword_Click"
                Margin="0,8,0,0">

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                        </Button>
                    </StackPanel>

                </Border>


                <Button Content="SAVE PROFILE"
                        Height="45"
                        Background="#00E5FF"
                        Foreground="Black"
                        FontWeight="Bold"
                        Click="SaveButton_Click">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                </Button>

            </StackPanel>

        </Border>

    </Grid>

</Window>