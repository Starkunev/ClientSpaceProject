<Window x:Class="WpfApp1.Views.Autarisation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация"
        Height="500"
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>

        <!-- Поля ввода -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,5,0,12"/>

            <Style.Triggers>
                <Trigger Property="Tag" Value="Error">
                    <Setter Property="Background" Value="#FFB6C1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,5,0,12"/>

            <Style.Triggers>
                <Trigger Property="Tag" Value="Error">
                    <Setter Property="Background" Value="#FFB6C1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Основная кнопка -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Вторичная кнопка -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Border Width="360"
                Background="White"
                CornerRadius="15"
                Padding="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="3"
                                  Opacity="0.15"/>
            </Border.Effect>

            <StackPanel>

                <TextBlock Text="Авторизация"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#111827"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Логин"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="txtLogin"/>

                <TextBlock Text="Пароль"
                           FontWeight="SemiBold"/>

                <PasswordBox x:Name="txtPassword"/>

                <TextBlock x:Name="lblStatus"
                           Foreground="Red"
                           TextAlignment="Center"
                           Margin="0,5,0,15"
                           TextWrapping="Wrap"/>

                <Button x:Name="btnLogin"
                        Content="Войти"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,0,10"
                        Click="BtnLogin_Click"/>

                <Button x:Name="btnRegister"
                        Content="Регистрация"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,0,15"
                        Click="BtnRegister_Click"/>

                <!-- Настройки сервера -->
                <Expander Header="Настройки сервера"
                          Foreground="#374151">

                    <StackPanel Margin="5">

                        <TextBlock Text="IP сервера"
                                   FontWeight="SemiBold"/>

                        <TextBox x:Name="txtServerIp"
                                 Text="127.0.0.1"/>

                        <TextBlock Text="Порт"
                                   FontWeight="SemiBold"/>

                        <TextBox x:Name="txtPort"
                                 Text="7000"/>

                    </StackPanel>

                </Expander>

            </StackPanel>

        </Border>

    </Grid>
</Window>