        <DataTemplate x:Key="MessageTemplate">
            <Border Margin="6,4" Padding="12" CornerRadius="16" MaxWidth="550">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#1E1E32"/>
                        <Setter Property="HorizontalAlignment" Value="Left"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMine}" Value="True">
                                <Setter Property="Background" Value="#7C4DFF"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Margin="0,0,10,0"
            ClipToBounds="True">
                        <Image>
                            <Image.Source>
                                <Binding Path="SenderAvatarBytes" Converter="{StaticResource ByteArrayToImageConverter}"/>
                            </Image.Source>
                        </Image>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Username}" Foreground="#B0B0D0" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="{Binding Message}" Foreground="White" 
                   TextWrapping="Wrap" FontSize="14" Margin="0,2,0,4"/>
                        <TextBlock Text="{Binding Time}" Foreground="#666688" FontSize="10" 
                   HorizontalAlignment="Right"/>
                    </StackPanel>

                    <!-- Кнопка удаления -->
                    <Button Grid.Column="2" 
                    Content="✕" 
                    Width="20" Height="20"
                    FontSize="10"
                    Foreground="#FF5252"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Top"
                    Margin="5,0,0,0"
                    Click="DeleteMessage_Click"
                    Tag="{Binding}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMine}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="8" Background="#121225" CornerRadius="16" Padding="8">
            <StackPanel>
                <TextBlock Text="👥 УЧАСТНИКИ" Foreground="White" FontSize="18" 
                           FontWeight="Bold" Margin="12,12,12,8"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="550">
                    <ListBox x:Name="UsersList"
                             ItemTemplate="{StaticResource UserTemplate}"
                             Background="Transparent"
                             BorderThickness="0"
                             MouseDoubleClick="UsersList_MouseDoubleClick"/>
                </ScrollViewer>

                <Button Content="👤 ПРОФИЛЬ" Margin="4,8" Click="ProfileButton_Click"
                        Style="{StaticResource GradientButton}"/>

                <Button Content="🚪 ВЫХОД" Margin="4,4" Click="ExitButton_Click"
                        Style="{StaticResource ExitButtonStyle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="65"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Background="#121225" CornerRadius="16" Grid.Row="0">
                <Grid>
                    <TextBlock Text="💬 ОБЩИЙ ЧАТ" Foreground="White" FontSize="22"
                               FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Users.Count, StringFormat='🟢 {0} онлайн'}" 
                               Foreground="#66BB6A" FontSize="14" HorizontalAlignment="Right" 
                               VerticalAlignment="Center" Margin="0,0,20,0"/>
                </Grid>
            </Border>

            <ListBox x:Name="MessagesList"
                     Grid.Row="1"
                     ItemTemplate="{StaticResource MessageTemplate}"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="0,8"/>

            <TextBlock x:Name="TypingText" Grid.Row="2" 
                       Foreground="#8888AA" FontStyle="Italic" 
                       Margin="12,0" FontSize="12" Height="20"/>

            <Border Grid.Row="3" Background="#121225" CornerRadius="16" Padding="8" Margin="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="😊" Click="EmojiButton_Click" 
                            Style="{StaticResource GradientButton}" Height="36" Width="36" 
                            FontSize="18" Padding="0"/>

                    <Button Grid.Column="1" Content="📎" Click="FileButton_Click"
                            Style="{StaticResource GradientButton}" Height="36" Width="36" 
                            FontSize="18" Padding="0" Margin="4,0,0,0"/>

                    <TextBox Grid.Column="2" x:Name="MessageTextBox" 
                             TextChanged="MessageTextBox_TextChanged"
                             KeyDown="MessageTextBox_KeyDown"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="36" MaxHeight="120"
                             Margin="8,0,8,0"
                             TextWrapping="Wrap"/>

                    <Button Grid.Column="3" Content="➤" Click="SendButton_Click"
                            Style="{StaticResource GradientButton}" Height="36" Width="44" 
                            FontSize="20" Padding="0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>