<Window x:Class="WpfApp1.ChatWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чат" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добро пожаловать в чат!" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>

        <ListBox x:Name="lstMessages" Grid.Row="1" Margin="0,10"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtMessage" Grid.Column="0" MinHeight="60" TextWrapping="Wrap"/>
            <Button x:Name="btnSend" Grid.Column="1" Content="Отправить" 
                    Width="80" Height="30" Margin="10,0,0,0"/>
        </Grid>
        <Label x:Name="lblStatus"
       HorizontalAlignment="Left"
       Margin="26,37,0,0"
       VerticalAlignment="Top"
       Grid.Row="1"/>
    </Grid>
</Window>